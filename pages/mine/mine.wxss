/* 本页样式继承自 app.wxss（全局），下方为训练记录相关补充 */

/* ===== 运动训练记录 ===== */
.empty {
  border: 1px dashed var(--line);
  border-radius: 14px;
  padding: 18px 16px;
  text-align: center;
  font-size: 13px;
  color: var(--muted);
  background: var(--surface-2);
  line-height: 1.6;
}
.traingroups { display: flex; flex-direction: column; gap: var(--gap-block); }
.tgroup {
  border: 1px solid var(--line);
  border-radius: 14px;
  overflow: hidden;
  background: var(--surface);
}
.tgh {
  font-size: 13.5px;
  font-weight: 800;
  color: var(--fg);
  padding: 10px 14px;
  background: var(--surface-2);
  border-bottom: 1px solid var(--line);
}
.titem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 14px;
  border-bottom: 1px solid var(--line);
}
.titem:last-child { border-bottom: none; }
.tit { font-size: 13.5px; color: var(--fg); line-height: 1.5; flex: 1; }
.tdel {
  flex: 0 0 auto;
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; line-height: 1;
  color: var(--muted);
  background: var(--surface-2);
  border: 1px solid var(--line);
  border-radius: 8px;
}

/* ===== 补记表单 ===== */
.addbar { margin-top: 14px; }
.addform {
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px;
  background: var(--surface-2);
}
.af-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.af-k { flex: 0 0 48px; font-size: 13.5px; color: var(--muted); font-weight: 600; }
.af-input {
  flex: 1;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 9px 12px;
  font-size: 14px;
}
.af-acts { display: flex; gap: 10px; margin-top: 4px; }
.btn-ghost {
  background: var(--surface);
  border: 1px solid var(--line);
  color: var(--muted);
}

/* ===== 训练时长趋势图（纯 CSS 柱状，无图表库） ===== */
.trend { margin: 14px 0 4px; border: 1px solid var(--line); border-radius: 14px; padding: 14px; background: var(--surface); }
.trend-h { font-size: 12.5px; color: var(--muted); font-weight: 700; margin-bottom: 10px; }
.trend-row { display: flex; align-items: flex-end; gap: 8px; padding: 8px 0; border-bottom: 1px dashed var(--line); }
.trend-row:last-child { border-bottom: none; }
.twd { flex: 0 0 36px; font-size: 12.5px; font-weight: 700; color: var(--fg); }
.tbars { flex: 1; display: flex; align-items: flex-end; gap: 5px; height: 60px; }
.tbar { flex: 1 1 0; min-width: 12px; max-width: 22px; background: linear-gradient(180deg, var(--brand) 0%, var(--brand-weak) 100%); border-radius: 4px 4px 0 0; position: relative; min-height: 6px; }
.tval { position: absolute; top: -15px; left: 50%; transform: translateX(-50%); font-size: 10px; color: var(--muted); font-weight: 700; white-space: nowrap; }
.tavg { flex: 0 0 42px; text-align: right; font-size: 12px; color: var(--muted); font-weight: 700; }
