/* 本页：分类导航（方法论 / 营养 / 训练） */
.knav { display: flex; flex-direction: column; height: 100vh; }
.segtab {
  display: flex;
  gap: var(--gap-card);
  padding: 10px var(--pad-page);
  background: var(--surface);
  border-bottom: 1px solid var(--line);
}
.seg {
  flex: 1;
  text-align: center;
  padding: 9px 0;
  border-radius: 11px;
  font-size: 14px;
  font-weight: 600;
  color: var(--muted);
  background: var(--surface-2);
  border: 1px solid var(--line);
  transition: all .2s ease;
}
.seg.on {
  color: #fff;
  background: var(--brand);
  border-color: var(--brand);
}
.kb {
  flex: 1;
  min-height: 0;
  overflow: hidden;
  padding: 16px var(--pad-page) 28px;
  box-sizing: border-box;
}
.cat { margin-bottom: var(--gap-block); }
.cat:last-child { margin-bottom: 0; }
